[Unit]
Description=kodi rockchip rkmpp gbm standalone via alsa
After=network-online.target

[Service]
EnvironmentFile=-/etc/default/kodi-rockchip-gbm
Environment=HOME=/root
# Also, set required interval for mpp utilization statistics https://github.com/armbian/linux-rockchip/commit/22c5e525ac2d6f7e17a8ba4722bf99240ee027a2 - see it with watch -n 1 cat /proc/mpp_service/load
ExecStartPre=/bin/bash -c 'echo 1000 > /proc/mpp_service/load_interval;'
ExecStart=/usr/local/bin/kodi --logging=console --windowing=gbm --audio-backend=alsa
TimeoutStopSec=5
Restart=always
RestartSec=2
StartLimitInterval=0
LimitNOFILE=16384

[Install]
WantedBy=multi-user.target
